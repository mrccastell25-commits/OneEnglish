  { q:"What kind of creature is a leprechaun?", opts:["A giant","A pirate","A magical fairy","A talking sheep"], correct:2 },
  { q:"If you catch a leprechaun, he must:", opts:["Give you his clothes","Make you shoes","Tell you where his gold is","Pinch your friends"], correct:2 },
  { q:"How did Patrick get to Ireland the first time?", opts:["He moved for work","He went on vacation","He was captured by pirates","He was born there"], correct:2 },
  { q:"What are the main elements of the celebration?", opts:["Sleeping and quiet music","Green clothes, parades, and dancing","Catching pirates on boats","Painting houses green"], correct:1 },
  { q:"Ireland is very green, that is why its nickname is:", opts:["The Green Island","The Emerald Isle","The Golden Land","The Shamrock Isle"], correct:1 }
];

const CELL_ICONS = {
  start: '🚩',
  finish: '🏆',
  quiz: '❓',
  boost: '⭐',
  back2: '⬇️',
  fwd2: '⬆️',
  normal: ['☘️','🍀','🌿','🌈','🪙','🎩','🐍','⛺','🏔️']
};

// ── STATE ──────────────────────────────────────────────────────────────
let players = [];
let currentPlayer = 0;
let diceRolled = false;
let quizAnswered = false;
let quizCorrect = false;
let usedQuestions = [];
let gameStarted = false;

// ── SETUP ──────────────────────────────────────────────────────────────
function initSetup() {
  const grid = document.getElementById('players-grid');
  grid.innerHTML = '';
  for (let i = 0; i < 4; i++) {
    const cfg = PLAYER_CONFIGS[i];
    const div = document.createElement('div');
