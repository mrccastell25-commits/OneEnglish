<script>
// ── NARRATOR (Web Speech API) ─────────────────────────────────────────
const NARRATOR = (() => {
  let femaleVoice = null;
  let isSpeaking = false;

  // Pre-load voices (async on some browsers)
  function loadVoices() {
    const voices = window.speechSynthesis.getVoices();
    // Priority: female English voices
    const preferred = [
      'Samantha', 'Victoria', 'Karen', 'Moira', 'Fiona',
      'Tessa', 'Veena', 'Zira', 'Susan', 'Emma',
      'Google US English', 'Microsoft Zira', 'Microsoft Emma'
    ];
    for (const name of preferred) {
      const v = voices.find(v => v.name.includes(name) && v.lang.startsWith('en'));
      if (v) { femaleVoice = v; return; }
    }
    // Fallback: any English female or just English
    femaleVoice =
      voices.find(v => v.lang.startsWith('en-') && /female|woman|girl/i.test(v.name)) ||
      voices.find(v => v.lang === 'en-US') ||
      voices.find(v => v.lang.startsWith('en')) ||
      null;
  }

  if (typeof speechSynthesis !== 'undefined') {
    loadVoices();
    window.speechSynthesis.onvoiceschanged = loadVoices;
  }

  function stop() {
    if (typeof speechSynthesis !== 'undefined') {
      window.speechSynthesis.cancel();
    }
    isSpeaking = false;
    const btn = document.getElementById('speak-btn');
    if (btn) btn.classList.remove('speaking');
  }

  function speak(text, onEnd) {
    if (typeof speechSynthesis === 'undefined') return;
    stop();
    const utt = new SpeechSynthesisUtterance(text);
    if (femaleVoice) utt.voice = femaleVoice;
    utt.lang = 'en-US';
    utt.rate = 0.92;
    utt.pitch = 1.1;
    utt.volume = 1.0;

    isSpeaking = true;
    const btn = document.getElementById('speak-btn');
    if (btn) btn.classList.add('speaking');

    utt.onend = () => {
      isSpeaking = false;
      if (btn) btn.classList.remove('speaking');
      if (onEnd) onEnd();
    };
    utt.onerror = () => {
      isSpeaking = false;
      if (btn) btn.classList.remove('speaking');
    };
    window.speechSynthesis.speak(utt);
  }

  return { speak, stop, isAvailable: () => typeof speechSynthesis !== 'undefined' };
})();

// ── SOUND ENGINE (Web Audio API) ──────────────────────────────────────
const SFX = (() => {
  let ctx = null;
  function getCtx() {
    if (!ctx) ctx = new (window.AudioContext || window.webkitAudioContext)();
    if (ctx.state === 'suspended') ctx.resume();
    return ctx;
  }

  function tone(freq, type, vol, attack, sustain, release, delay=0) {
    const c = getCtx();
    const osc = c.createOscillator();
    const gain = c.createGain();
    osc.connect(gain); gain.connect(c.destination);
    osc.type = type;
    osc.frequency.setValueAtTime(freq, c.currentTime + delay);
    gain.gain.setValueAtTime(0, c.currentTime + delay);
    gain.gain.linearRampToValueAtTime(vol, c.currentTime + delay + attack);
    gain.gain.setValueAtTime(vol, c.currentTime + delay + attack + sustain);
    gain.gain.linearRampToValueAtTime(0, c.currentTime + delay + attack + sustain + release);
    osc.start(c.currentTime + delay);
    osc.stop(c.currentTime + delay + attack + sustain + release + 0.01);
  }

  function noise(vol, duration, delay=0) {
    const c = getCtx();
    const buf = c.createBuffer(1, c.sampleRate * duration, c.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;
    const src = c.createBufferSource();
    src.buffer = buf;
    const gain = c.createGain();
    const filter = c.createBiquadFilter();
    filter.type = 'bandpass'; filter.frequency.value = 800; filter.Q.value = 0.5;
    src.connect(filter); filter.connect(gain); gain.connect(c.destination);
    gain.gain.setValueAtTime(vol, c.currentTime + delay);
    gain.gain.linearRampToValueAtTime(0, c.currentTime + delay + duration);
    src.start(c.currentTime + delay);
    src.stop(c.currentTime + delay + duration + 0.01);
  }

  return {
    // Dice rolling: rapid random clicks
    diceRoll() {
      for (let i = 0; i < 6; i++) {
        noise(0.15, 0.04, i * 0.07);
        tone(80 + Math.random()*40, 'square', 0.1, 0.005, 0.02, 0.03, i*0.07);
      }
    },
    // Dice result: two-tone thud
    diceResult(val) {
      const base = 150 + val * 20;
      tone(base, 'sine', 0.35, 0.01, 0.06, 0.12);
      tone(base * 1.5, 'sine', 0.18, 0.01, 0.04, 0.1, 0.05);
    },
    // Step: small tick per house
    step() {
      tone(440, 'square', 0.08, 0.005, 0.01, 0.04);
    },
    // Quiz appears: mysterious ascending arp
    quizOpen() {
      [330, 392, 494, 587].forEach((f, i) => tone(f, 'triangle', 0.2, 0.01, 0.06, 0.1, i*0.09));
    },
    // Correct answer: cheerful fanfare
    correct() {
      [[523,0],[659,0.12],[784,0.24],[1047,0.38]].forEach(([f,d]) => tone(f,'triangle',0.25,0.01,0.1,0.12,d));
      tone(523,'sine',0.15,0.01,0.3,0.2,0.5);
    },
    // Wrong answer: descending blip
    wrong() {
      tone(440,'sawtooth',0.2,0.01,0.05,0.08);
      tone(330,'sawtooth',0.2,0.01,0.05,0.08,0.12);
      tone(220,'sawtooth',0.2,0.01,0.08,0.12,0.24);
    },
    // Boost / bonus: upward sparkle
    boost() {
      [523,659,784,1047,1319].forEach((f,i) => tone(f,'sine',0.18,0.005,0.05,0.08,i*0.06));
    },
    // Back: descending gloom
    back() {
      [400,320,240,180].forEach((f,i) => tone(f,'sawtooth',0.18,0.005,0.06,0.1,i*0.08));
    },
    // Start Adventure: heroic ascending fanfare
    startAdventure() {
      [261,330,392,523,659,784].forEach((f,i) => tone(f,'triangle',0.22,0.01,0.08,0.12,i*0.07));
      tone(1047,'sine',0.28,0.01,0.25,0.3,0.5);
    },
    // Next turn: soft blip
    nextTurn() {
      tone(392,'sine',0.2,0.01,0.04,0.1);
      tone(523,'sine',0.15,0.01,0.04,0.1,0.1);
    },
    // Win: full victory fanfare
    win() {
      const melody = [[523,0],[659,0.15],[784,0.30],[1047,0.45],[784,0.65],[1047,0.80],[1319,1.0]];
      melody.forEach(([f,d]) => tone(f,'triangle',0.28,0.02,0.12,0.15,d));
      // harmony
      const harm = [[330,0],[415,0.15],[494,0.30],[659,0.45]];
      harm.forEach(([f,d]) => tone(f,'sine',0.12,0.02,0.12,0.15,d));
    }
  };
})();

// ── DATA ──────────────────────────────────────────────────────────────
const PLAYER_CONFIGS = [
  { emoji: '🍀', color: '#27ae60', bg: '#1a4d1a' },
  { emoji: '🌈', color: '#e74c3c', bg: '#4d1a1a' },
  { emoji: '🪙', color: '#f0b429', bg: '#4d3800' },
  { emoji: '🎩', color: '#9b59b6', bg: '#2d1a4d' }
];

const TOTAL_CELLS = 30;

// Cell types: start, finish, quiz, back2, fwd2
const CELL_TYPES = { 0:'start', 29:'finish' };
const BACK2_CELLS = [8];
const FWD2_CELLS  = [20];
const BOOST_CELLS = [];
function isQuizCell(idx) {
  if (idx === 0 || idx === TOTAL_CELLS - 1) return false;
  if (BACK2_CELLS.includes(idx) || FWD2_CELLS.includes(idx)) return false;
  return true;
}
const QUIZ_CELLS = Array.from({length: TOTAL_CELLS}, (_, i) => i).filter(isQuizCell);

const DICE_FACES = ['⚀','⚁','⚂','⚃','⚄','⚅'];

const QUESTIONS = [
  { q:"When is St. Patrick\u0027s Day celebrated?", opts:["May 17","March 7","March 17","April 17"], correct:2 },
  { q:"Why is Ireland called the Emerald Isle?", opts:["Because there are many pirates","Because the island is very green","Because it has a lot of gold","Because of the blue rivers"], correct:1 },
  { q:"How old was Patrick when he was captured by pirates?", opts:["Six years old","Sixty years old","Sixteen years old","Ten years old"], correct:2 },
  { q:"What job did Patrick do for six years in Ireland?", opts:["He was a pirate","He was a shepherd","He was a shoemaker","He was a cook"], correct:1 },
  { q:"Patrick used the shamrock to explain:", opts:["How to find gold","How to cook traditional food","The Holy Trinity","How to escape from the island"], correct:2 },
  { q:"What is a leprechaun\u0027s job in Irish legend?", opts:["Making shoes","Dyeing rivers green","Cooking corned beef","Dancing in parades"], correct:0 },
  { q:"Where does a leprechaun hide his gold?", opts:["In a green river","In a pot of gold","Inside a shamrock","Under a cabbage"], correct:1 },
  { q:"What is a traditional meal for St. Patrick\u0027s Day?", opts:["Green eggs and ham","Corned beef and cabbage","Pizza and soda","Fish and chips"], correct:1 },
