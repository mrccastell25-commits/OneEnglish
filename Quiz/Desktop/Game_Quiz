    div.addEventListener('click', e => {
      if (e.target.tagName === 'INPUT') return;
      div.classList.toggle('active');
    });
    grid.appendChild(div);
  }
}

function startGame() {
  const toggles = document.querySelectorAll('.player-toggle');
  players = [];
  toggles.forEach((t, i) => {
    if (t.classList.contains('active')) {
      const name = t.querySelector('input').value.trim() || `Player ${i+1}`;
      players.push({ name, pos: 0, cfg: PLAYER_CONFIGS[i], active: true });
    }
  });
  if (players.length < 1) { alert('Select at least 1 player!'); return; }

  SFX.startAdventure();
  currentPlayer = 0;
  diceRolled = false;
  usedQuestions = [];
  gameStarted = true;

  document.getElementById('setup-screen').style.display = 'none';
  const gs = document.getElementById('game-screen');
  gs.style.display = 'flex';

  buildBoard();
  buildPlayersBar();
  renderBoard();
  updateTurnUI();
}

// ── BOARD BUILD ──────────────────────────────────────────────────────────
function getCellType(idx) {
  if (idx === 0) return 'start';
  if (idx === TOTAL_CELLS - 1) return 'finish';
  if (BACK2_CELLS.includes(idx)) return 'back2';
  if (FWD2_CELLS.includes(idx)) return 'fwd2';
  return 'quiz';
}

function getCellIcon(idx) {
  const t = getCellType(idx);
  if (t === 'start') return '🚩';
  if (t === 'finish') return '🏆';
  if (t === 'quiz') return '❓';
  if (t === 'boost') return '⭐';
  if (t === 'back2') return '⬇️';
  if (t === 'fwd2') return '⬆️';
  const normalIcons = ['☘️','🍀','🌿','🌈','🪙','🎩','🐍','⛺','🏔️','🌸'];
  return normalIcons[idx % normalIcons.length];
}

// Build snake-path: row 0 → right, row 1 → left, etc.
function buildIndexMap() {
  // maps grid position (row, col) to cell index
  const map = {};
  const cols = 6;
  const rows = Math.ceil(TOTAL_CELLS / cols);
  let idx = 0;
  for (let r = rows - 1; r >= 0; r--) {
    const leftToRight = (rows - 1 - r) % 2 === 0;
    for (let c = 0; c < cols; c++) {
      if (idx >= TOTAL_CELLS) break;
      const col = leftToRight ? c : (cols - 1 - c);
      map[`${r}-${col}`] = idx;
      idx++;
    }
  }
  return map;
}

let indexToGrid = {};

function buildBoard() {
  const cols = 6;
  const rows = Math.ceil(TOTAL_CELLS / cols);
  const grid = document.getElementById('board-grid');
  grid.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
  grid.innerHTML = '';

  const posMap = buildIndexMap();
  // invert
  indexToGrid = {};
  for (const [key, val] of Object.entries(posMap)) { indexToGrid[val] = key; }

  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const key = `${r}-${c}`;
      const idx = posMap[key];
      if (idx === undefined) {
        const blank = document.createElement('div');
        blank.style.aspectRatio = '1';
        grid.appendChild(blank);
        continue;
      }
      const cell = document.createElement('div');
      const type = getCellType(idx);
      cell.className = `cell ${type}`;
      cell.id = `cell-${idx}`;
      const lbl = type === 'quiz' ? 'QUIZ' : type === 'back2' ? 'back 2' : type === 'fwd2' ? 'forward 2' : '';
      let extraHtml = '';
      if (type === 'start') {
        extraHtml = `<div class="diamond-wrap"><div class="diamond-shape"><div class="diamond-inner"><span class="diamond-flag">🚩</span><span class="diamond-txt">START</span></div></div></div>`;
      } else if (type === 'finish') {
        extraHtml = `<div class="diamond-wrap"><div class="diamond-shape"><div class="diamond-inner"><span class="diamond-flag">🏁</span><span class="diamond-txt">FINISH</span></div></div></div>`;
      }
      cell.innerHTML = `
        ${extraHtml}
        <div class="cell-num">${idx}</div>
        ${lbl ? `<div class="cell-label">${lbl}</div>` : ''}
        <div class="player-tokens" id="tokens-${idx}"></div>
      `;
      grid.appendChild(cell);
    }
  }
}

function buildPlayersBar() {
  const bar = document.getElementById('players-bar');
  bar.innerHTML = '';
  players.forEach((p, i) => {
    const chip = document.createElement('div');
    chip.className = 'player-chip' + (i === 0 ? ' active' : '');
    chip.id = `chip-${i}`;
    chip.innerHTML = `
      <div class="chip-icon">${p.cfg.emoji}</div>
      <div class="chip-info">
        <span class="chip-name">${p.name}</span>
        <span class="chip-pos" id="chip-pos-${i}">Square: 0</span>
      </div>
    `;
    bar.appendChild(chip);
  });
}

// ── RENDER ──────────────────────────────────────────────────────────────
function renderBoard() {
  // Clear all tokens
  document.querySelectorAll('.player-tokens').forEach(t => t.innerHTML = '');
  document.querySelectorAll('.cell').forEach(c => c.classList.remove('has-player'));

  players.forEach((p, i) => {
    const tokenDiv = document.getElementById(`tokens-${p.pos}`);
    if (!tokenDiv) return;
    const tok = document.createElement('div');
    tok.className = 'token';
    tok.style.background = p.cfg.bg;
    tok.style.borderColor = p.cfg.color;
    tok.textContent = p.cfg.emoji;
    tokenDiv.appendChild(tok);
    document.getElementById(`cell-${p.pos}`)?.classList.add('has-player');
  });

  players.forEach((p, i) => {
    const pos = document.getElementById(`chip-pos-${i}`);
    if (pos) pos.textContent = `Pos: ${p.pos}`;
  });
}

function updateTurnUI() {
  const p = players[currentPlayer];
  const label = document.getElementById('turn-label');
  label.innerHTML = `Turn: <span>${p.cfg.emoji} ${p.name}</span>`;

  // update chips
  document.querySelectorAll('.player-chip').forEach((c, i) => {
    c.classList.toggle('active', i === currentPlayer);
  });

  document.getElementById('status-msg').textContent = 'Tap the dice to roll!';
  document.getElementById('dice-num').textContent = '—';
  document.getElementById('dice-btn').style.display = 'flex';
  document.getElementById('btn-next').style.display = 'none';
  diceRolled = false;
  setTimeout(() => NARRATOR.speak('Play!'), 300);
}

// ── DICE ──────────────────────────────────────────────────────────────
function rollDice() {
  if (diceRolled) return;
  const btn = document.getElementById('dice-btn');
  btn.classList.add('rolling');
  btn.style.pointerEvents = 'none';

  // animate faces
  SFX.diceRoll();
  let ticks = 0;
  const interval = setInterval(() => {
    const face = Math.floor(Math.random() * 6);
    btn.textContent = DICE_FACES[face];
    ticks++;
    if (ticks > 8) {
      clearInterval(interval);
      const roll = Math.floor(Math.random() * 6) + 1;
      btn.textContent = DICE_FACES[roll - 1];
      btn.classList.remove('rolling');
      btn.style.pointerEvents = 'auto';
      SFX.diceResult(roll);
      processRoll(roll);
    }
  }, 60);
}

function processRoll(roll) {
  diceRolled = true;

  // Keep dice visible for 1.5s so players can clearly see the rolled face
  setTimeout(() => {
    document.getElementById('dice-btn').style.display = 'none';
    document.getElementById('dice-num').textContent = roll;
  }, 1500);

  const p = players[currentPlayer];
  const oldPos = p.pos;
  let newPos = Math.min(p.pos + roll, TOTAL_CELLS - 1);

  // animate movement — wait for dice to be hidden first
  setTimeout(() => animateMovement(oldPos, newPos, roll, () => {
    p.pos = newPos;
    renderBoard();

    const type = getCellType(newPos);

    if (newPos === TOTAL_CELLS - 1) {
      SFX.win();
      NARRATOR.speak(`Congratulations! You reached the finish! ${p.name} wins!`);
      document.getElementById('win-name').textContent = `${p.cfg.emoji} ${p.name}`;
      document.getElementById('win-screen').classList.add('show');
      return;
    }

    if (type === 'quiz') {
      document.getElementById('status-msg').textContent = '❓ Quiz time! Answer to keep playing.';
      setTimeout(() => showQuiz(), 600);
    } else if (type === 'back2') {
      const moved = Math.max(0, newPos - 2);
      p.pos = moved;
      renderBoard();
      SFX.back();
      NARRATOR.speak('Go back two spaces!');
      document.getElementById('status-msg').textContent = `⬇️ back 2! Moved to square ${moved}`;
      showNextBtn();
    } else if (type === 'fwd2') {
      const moved = Math.min(TOTAL_CELLS - 1, newPos + 2);
      p.pos = moved;
      renderBoard();
      SFX.boost();
      if (moved === TOTAL_CELLS - 1) {
        SFX.win();
        NARRATOR.speak(`Congratulations! You reached the finish! ${p.name} wins!`);
        document.getElementById('win-name').textContent = `${p.cfg.emoji} ${p.name}`;
        document.getElementById('win-screen').classList.add('show');
        return;
      }
      NARRATOR.speak('Move forward two spaces!');
      document.getElementById('status-msg').textContent = `⬆️ forward 2! Moved to square ${moved}`;
      showNextBtn();
    } else {
      document.getElementById('status-msg').textContent = `Moved to square ${newPos}`;
      showNextBtn();
    }
  }), 1600);
}

let moveTimer = null;

function animateMovement(from, to, roll, callback) {
  let cur = from;
  const step = () => {
    if (cur === to) { callback(); return; }
    // highlight current
    document.getElementById(`cell-${cur}`)?.classList.remove('has-player');
    cur++;
    const cell = document.getElementById(`cell-${cur}`);
    if (cell) {
      cell.classList.add('has-player');
      cell.style.transform = 'scale(1.15)';
      SFX.step();
      setTimeout(() => { cell.style.transform = ''; }, 180);
    }
    setTimeout(step, 130);
  };
  step();
}

function showNextBtn() {
  const btn = document.getElementById('btn-next');
  btn.style.display = 'block';
}

function nextTurn() {
  SFX.nextTurn();
  currentPlayer = (currentPlayer + 1) % players.length;
  updateTurnUI();
}

// ── QUIZ ──────────────────────────────────────────────────────────────
let currentQuestion = null;

function getRandomQuestion() {
  if (usedQuestions.length >= QUESTIONS.length) usedQuestions = [];
  const available = QUESTIONS.filter((_, i) => !usedQuestions.includes(i));
  const pick = Math.floor(Math.random() * available.length);
  const idx = QUESTIONS.indexOf(available[pick]);
  usedQuestions.push(idx);
  return QUESTIONS[idx];
}

function speakQuestion() {
  if (!currentQuestion) return;
  const text = currentQuestion.q + '. ' +
    currentQuestion.opts.map((o, i) => ['A','B','C','D'][i] + '. ' + o).join('. ');
  NARRATOR.speak(text);
}

function showQuiz() {
  currentQuestion = getRandomQuestion();
  const p = players[currentPlayer];

  document.getElementById('quiz-player-tag').textContent = `${p.cfg.emoji} ${p.name}`;
  document.getElementById('quiz-q').textContent = currentQuestion.q;

  const optContainer = document.getElementById('quiz-options');
  optContainer.innerHTML = '';
  const letters = ['A','B','C','D'];
  currentQuestion.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-opt';
    btn.innerHTML = `<span class="opt-letter">${letters[i]}</span>${opt}`;
    btn.onclick = () => answerQuiz(i);
    optContainer.appendChild(btn);
  });

  document.getElementById('quiz-feedback').style.display = 'none';
  document.getElementById('quiz-feedback').className = 'quiz-feedback';
  document.getElementById('btn-dismiss').style.display = 'none';
  SFX.quizOpen();
  document.getElementById('quiz-overlay').classList.add('show');
  // Auto-narrate after a short pause so quiz SFX plays first
  setTimeout(() => speakQuestion(), 700);
}

function answerQuiz(idx) {
  NARRATOR.stop();
  const opts = document.querySelectorAll('.quiz-opt');
  opts.forEach(o => { o.classList.add('disabled'); o.onclick = null; });

  const correct = currentQuestion.correct;
  opts[correct].classList.add('correct');

  const feedback = document.getElementById('quiz-feedback');
  const dismiss = document.getElementById('btn-dismiss');

  if (idx === correct) {
    SFX.correct();
    NARRATOR.speak('Congratulations!');
    feedback.textContent = '🎉 Correct! Next player\'s turn.';
    feedback.className = 'quiz-feedback correct';
    quizCorrect = true;
  } else {
    SFX.wrong();
    opts[idx].classList.add('wrong');
    NARRATOR.speak('Sorry!');
    feedback.textContent = `❌ Wrong! Passing to next player.`;
    feedback.className = 'quiz-feedback wrong';
    quizCorrect = false;
  }

  feedback.style.display = 'block';
  dismiss.style.display = 'block';
}

function dismissQuiz() {
  NARRATOR.stop();
  document.getElementById('quiz-overlay').classList.remove('show');
  if (quizCorrect) {
    document.getElementById('status-msg').textContent = '✅ Correct! Next player\'s turn.';
  } else {
    document.getElementById('status-msg').textContent = '❌ Wrong answer. Next player!';
  }
  showNextBtn();
}

// ── WIN / RESTART ──────────────────────────────────────────────────────
function restartGame() {
  document.getElementById('win-screen').classList.remove('show');
  document.getElementById('game-screen').style.display = 'none';
  document.getElementById('setup-screen').style.display = 'flex';
  gameStarted = false;
  initSetup();
}

// ── INIT ──────────────────────────────────────────────────────────────
initSetup();
</script>
</body>
